# Anthropic API Key (用于 sniper 和 writer)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Anthropic API Base URL (可选，用于第三方 API 中转服务)
# 留空则使用官方 API: https://api.anthropic.com
# 示例: https://api.example.com/v1
ANTHROPIC_BASE_URL=

# Notion Integration Token
NOTION_API_KEY=your_notion_integration_token_here

# Notion Database ID (存储文章的数据库)
# 示例: Ready Content database
NOTION_DATABASE_ID=3174da82-1152-80f4-b455-f4bd1188a326
